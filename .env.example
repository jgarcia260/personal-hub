# OpenAI API Key (for embeddings generation)
# Get your key from: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Pinecone API Key and Index URL (for vector storage)
# Get your key from: https://www.pinecone.io/
# Create an index with dimension=1536 and metric=cosine
EXPO_PUBLIC_PINECONE_API_KEY=...
EXPO_PUBLIC_PINECONE_INDEX_URL=https://your-index-xxxxx.svc.environment.pinecone.io

# Notes:
# - Copy this file to .env and fill in your actual keys
# - Never commit .env to version control (already in .gitignore)
# - text-embedding-3-small uses 1536 dimensions
# - Pinecone free tier: 1M vectors, 100K queries/month
